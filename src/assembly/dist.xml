<assembly xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.3 https://maven.apache.org/xsd/assembly-1.1.3.xsd">
  <id>dist</id>
  <formats>
    <format>zip</format>
  </formats>
  <includeBaseDirectory>true</includeBaseDirectory>

  <fileSets>
    <!-- Startskript(e) -->
    <fileSet>
      <directory>src/dist/bin</directory>
      <outputDirectory>bin</outputDirectory>
      <fileMode>0755</fileMode>
      <lineEnding>dos</lineEnding>
    </fileSet>

    <!-- Editierbare Konfiguration -->
    <fileSet>
      <directory>src/dist/config</directory>
      <outputDirectory>config</outputDirectory>
    </fileSet>

    <!-- Leerer Logs-Ordner -->
    <fileSet>
      <directory>src/dist/logs</directory>
      <outputDirectory>logs</outputDirectory>
      <includes>
        <include>.gitkeep</include>
      </includes>
    </fileSet>

    <!-- OPTIONAL: portable JRE. 
         Entweder den Block löschen, wenn du keine JRE beilegst,
         oder sicherstellen, dass der Ordner existiert (ggf. leer + .gitkeep). -->
    <fileSet>
      <directory>src/dist/jre</directory>
      <outputDirectory>jre</outputDirectory>
      <useDefaultExcludes>true</useDefaultExcludes>
    </fileSet>
  </fileSets>

  <files>
    <!-- Fat-Jar als stabiler Name -->
    <file>
      <source>${project.build.directory}/${project.artifactId}-${project.version}-all.jar</source>
      <outputDirectory>lib</outputDirectory>
      <destName>${project.artifactId}.jar</destName>
    </file>
  </files>
</assembly>
